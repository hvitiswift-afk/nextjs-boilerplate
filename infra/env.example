# Goblin + Fabian Enclave environment template
# Copy to your deployment provider's environment settings. Do not commit real secrets.

NODE_ENV=development
APPROVAL_REQUIRED=true

# Local model endpoints
LOCAL_LLM_URL=http://localhost:11434
FABIAN_LLM_URL=http://localhost:11435

# Memory vault
DATABASE_URL=postgres://goblin:goblin@localhost:5432/goblin

# Optional commercial LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# PayPal receipt spine
PAYPAL_CLIENT_ID=
PAYPAL_WEBHOOK_ID=

# Outpost
OUTPOST_ID=2099-2100
OUTPOST_RETURN_BASE_URL=/api/outpost/entry

# Cloudflare
CLOUDFLARE_WORKER_NAME=goblin-edge-bridge
